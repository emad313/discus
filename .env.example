# Docker Environment Variables
# Copy this to .env and update values

# Application
NODE_ENV=production
PUBLIC_IP=127.0.0.1

# Database (PostgreSQL)
DB_USER=discus
DB_PASSWORD=discus_secure_password_change_me
DB_NAME=discus

# Redis
REDIS_PASSWORD=redis_secure_password_change_me

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_change_this

# Mediasoup (for 100+ users)
MEDIASOUP_NUM_WORKERS=4
MEDIASOUP_MIN_PORT=10000
MEDIASOUP_MAX_PORT=10100

# TURN/STUN
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpassword_change_me
TURN_REALM=discus.local
